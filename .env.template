# --- GO2RTC / Kamera (PC, Scout oder On-Demand-Webcam) ---
# PC: go2rtc aus driver/go2rtc_win64/, Base-URL localhost:1984.
# Scout: go2rtc auf dem Pi; Base-URL = Scout-IP (z. B. http://scout.local:1984).
# GO2RTC_BASE_URL=http://localhost:1984
# GO2RTC_STREAM_NAME=pc
# On-Demand-Webcam (Brio nur bei Abruf aktiv): camera_snapshot_server.py starten, dann:
# CAMERA_SNAPSHOT_URL=http://localhost:8555/snapshot.jpg
# CAMERA_DEVICE_NAME=Logitech BRIO
# CAMERA_SNAPSHOT_PORT=8555
# CAMERA_VIDEO_SIZE=1280x720
# FFmpeg: Standard = driver/go2rtc_win64/ffmpeg.exe (cwd = dieser Ordner). Optional System-Pfad:
# FFMPEG_PATH=C:\Pfad\zu\ffmpeg.exe
# Brio-Szenario: Laufzeit-Erkennung braucht mind. 1×/Min; 50 nur für ersten Test
# BRIO_SCENARIO_INTERVAL_MIN=1
# BRIO_SCENARIO_DURATION_MIN=60
# BRIO_SCENARIO_MAX_EXTRA=5
# BRIO_VISION_MODEL=gemini-3.1-pro-preview
# BRIO_VISION_FALLBACK=gemini-3-pro-preview   # falls 3.1 Pro nicht verfügbar (z. B. Gemini 3 Pro)
# GEMINI_HEAVY_MODEL=gemini-3.1-pro-preview   # LLM-Interface (Tier 5)
# GEMINI_AUDIO_MODEL=gemini-3.1-pro-preview    # WhatsApp Sprachnachricht
# Tapo (Balkon): Einzelbild für Erkennungstest Garten. URL von go2rtc (go2rtc holt Frame per FFmpeg vom RTSP)
# TAPO: frame.jpeg = direkt JPEG (empfohlen); frame.mp4 = MP4, Skript extrahiert Frame
# TAPO_FRAME_URL=https://home:8123/api/hassio_ingress/<TOKEN>/api/frame.jpeg?src=Balkon_HD
# TAPO_RTSP_URL=rtsp://<Scout-IP>:8554/Balkon_HD
# TAPO_SAVE_DIR=c:\ATLAS_CORE\data\tapo_garden
# TAPO_RUN_ANALYSIS=1

# --- BACKUP (Ziel: Hostinger, siehe docs/BACKUP_PLAN_FINAL.md) ---
