4. src/api/middleware/veto_gate.py (PATCH: A-23)
Kryptographische Härte (HMAC-SHA256) anstelle von reiner Header-Existenz.

Python
import hmac
import hashlib
import os
from fastapi import Request, HTTPException

# Secret muss zwingend aus Umgebungsvariablen / Vault kommen
VETO_SECRET = os.environ.get("MTHO_VETO_SECRET", "").encode('utf-8')

async def verify_veto_signature(request: Request):
    if not VETO_SECRET:
        raise HTTPException(status_code=500, detail="VETO_SECRET not configured")

    signature = request.headers.get("X-Veto-Signature")
    if not signature:
        raise HTTPException(status_code=401, detail="Missing Veto Signature")

    body = await request.body()
    expected_mac = hmac.new(VETO_SECRET, body, hashlib.sha256).hexdigest()

    if not hmac.compare_digest(expected_mac, signature):
        raise HTTPException(status_code=403, detail="Invalid Veto Signature")
5. src/config/ring0_state.py (PATCH: A-29)
Caller-Validierung durch den Stack-Inspector. Ring-0 Schreibschutz.

Python
import inspect
import logging

logger = logging.getLogger("mtho_core.ring0")

ALLOWED_CALLERS = [
    "z_vector_damper.py",
    "entry_adapter.py",
    "mtho_vision_daemon.py"
]

def _verify_caller():
    # A-29: Caller-Validierung für kritische State-Overrides
    stack = inspect.stack()
    # stack[0] ist _verify_caller, stack[1] ist set_drift_veto, stack[2] ist der echte Caller
    if len(stack) > 2:
        caller_frame = stack[2]
        caller_filename = caller_frame.filename.split('/')[-1].split('\\')[-1]

        if caller_filename not in ALLOWED_CALLERS:
            logger.critical(f"UNAUTHORIZED Ring-0 Access from {caller_filename}")
            raise PermissionError(f"Module {caller_filename} is not allowed to mutate Ring-0 state.")
