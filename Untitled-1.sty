import logging
from typing import List, Dict, Any

logger = logging.getLogger("mtho_core.baryonic_filter")

BARYONIC_DELTA = 0.049
SYMMETRY_HIGH = 0.51
SYMMETRY_LOW = 0.49

class BaryonicNoiseFilter:
    def __init__(self, resonance_threshold: float = SYMMETRY_HIGH):
        # Axiom-Check: Exakte Mitte 0.5 ist verboten
        if abs(resonance_threshold - 0.5) < 0.001:
            self.resonance_threshold = SYMMETRY_HIGH
        else:
            self.resonance_threshold = resonance_threshold

    def filter_noise(self, vectors: List[Dict[str, Any]]) -> List[Dict[str, Any]]:
        filtered = []
        for vec in vectors:
            score = vec.get("score", 0.0) # Raw Cosine Distance

            # Harter Kollaps: Entweder hohe Resonanz (>= 0.51) oder Grundrauschen ignorieren
            if score >= self.resonance_threshold:
                filtered.append(vec)
            elif score <= SYMMETRY_LOW:
                # Delta-Erhalt bei extrem schwachen Signalen (Rauschen filtern)
                pass

        logger.info(f"Baryonic Filter: {len(vectors)} in, {len(filtered)} out. Threshold: {self.resonance_threshold}")
        return filtered
