Speichere dieses Skript im Hauptverzeichnis und führe es isoliert aus, bevor der CORE den regulären Betrieb wieder aufnimmt.

Python
import os
import chromadb
import logging
from chromadb.utils import embedding_functions

# Logging initialisieren
logging.basicConfig(level=logging.INFO, format='%(levelname)s: %(message)s')
logger = logging.getLogger("core.chroma_migration")

# Infrastruktur-Parameter (int)
CHROMA_PATH = "./chroma_db"
BATCH_SIZE = 100

# Mapping für die harte semantische Übersetzung
TRANSLATION_MAP = {
    "MTHO": "GTAC",
    "mtho": "gtac",
    "LPIS": "LISP",
    "lpis": "lisp",
    "Munin": "Context_Injector",
    "Wuji": "Zero-State",
    "wuji": "zero_state",
    "Argos": "Shell"
}

def translate_text(text: str) -> str:
    if not text:
        return text
    translated = text
    for old_val, new_val in TRANSLATION_MAP.items():
        translated = translated.replace(old_val, new_val)
    return translated

def translate_metadata(metadata: dict) -> dict:
    if not metadata:
        return metadata
    translated_meta = {}
    for k, v in metadata.items():
        new_k = translate_text(k)
        new_v = translate_text(v) if isinstance(v, str) else v
        translated_meta[new_k] = new_v
    return translated_meta

def migrate_collection(client: chromadb.PersistentClient, collection_name: str, embed_fn):
    logger.info(f"Starte Migration für Collection: {collection_name}")
    try:
        collection = client.get_collection(name=collection_name, embedding_function=embed_fn)
    except Exception as e:
        logger.warning(f"Collection {collection_name} nicht gefunden oder fehlerhaft: {e}")
        return

    # Extraktion aller Daten
    data = collection.get()
    ids = data.get("ids", [])
    documents = data.get("documents", [])
    metadatas = data.get("metadatas", [])

    if not ids:
        logger.info(f"Collection {collection_name} ist leer. Überspringe.")
        return

    logger.info(f"{len(ids)} Vektoren in {collection_name} gefunden. Starte Re-Embedding...")

    updated_docs = []
    updated_metas = []

    # Translation
    for i in range(len(ids)):
        doc = documents[i] if documents else ""
        meta = metadatas[i] if metadatas else {}

        updated_docs.append(translate_text(doc))
        updated_metas.append(translate_metadata(meta))

    # Re-Embedding in Batches (verhindert Memory-Kollaps)
    for i in range(0, len(ids), BATCH_SIZE):
        batch_ids = ids[i:i+BATCH_SIZE]
        batch_docs = updated_docs[i:i+BATCH_SIZE]
        batch_metas = updated_metas[i:i+BATCH_SIZE]

        # Update zwingt ChromaDB, die Embeddings für die neuen Texte neu zu berechnen
        collection.update(
            ids=batch_ids,
            documents=batch_docs,
            metadatas=batch_metas
        )
        logger.info(f"Batch {i} bis {i+len(batch_ids)} verarbeitet.")

    logger.info(f"Migration für {collection_name} abgeschlossen.")

def run_migration():
    if not os.path.exists(CHROMA_PATH):
        logger.error(f"Datenbankpfad {CHROMA_PATH} nicht gefunden.")
        return

    client = chromadb.PersistentClient(path=CHROMA_PATH)

    # HINWEIS: Ersetze dies durch deine spezifische Embedding-Funktion (z.B. Ollama oder OpenAI),
    # falls du nicht die Chroma-Default-Funktion nutzt.
    embed_fn = embedding_functions.DefaultEmbeddingFunction()

    collections_to_migrate = ["world_knowledge", "wuji_context", "events"]

    for coll in collections_to_migrate:
        migrate_collection(client, coll, embed_fn)

if __name__ == "__main__":
    run_migration()
Das Skript lädt die Rohdaten, wendet die semantische Zerstörung der alten Metaphern an und schreibt die mathematisch korrekten GTAC/LISP-Strukturen zurück. Durch die collection.update()-Methode wird der latente Raum physisch neu berechnet.

