import math
import logging
import chromadb
from typing import List

logging.basicConfig(level=logging.INFO, format='%(levelname)s: %(message)s')
logger = logging.getLogger("core.ingest_72")

# AXIOM-TYPISIERUNG: Infrastruktur (int), Resonanz (float)
TOTAL_ANCHORS: int = 72
DIMENSIONS: int = 5
PHI: float = 1.618033
LAMBDA_GRID: float = 0.049
SYMMETRY_BREAK: float = 0.49

def generate_5d_e6_anchors() -> List[List[float]]:
    """
    Generiert 72 asymmetrische Vektor-Koordinaten im 5D-Raum.
    Keine exakten 0.0, 1.0 oder 0.5 Werte. Zwingender Symmetriebruch.
    """
    anchors = []
    # Oszillierende Generation entlang des Torus
    for i in range(TOTAL_ANCHORS):
        # Basis-Winkel zur Vermeidung von Singularitäten
        theta: float = (i * PHI * math.pi) % (2 * math.pi)

        v1: float = SYMMETRY_BREAK + (LAMBDA_GRID * math.sin(theta))
        v2: float = SYMMETRY_BREAK + (LAMBDA_GRID * math.cos(theta * PHI))
        v3: float = SYMMETRY_BREAK + (LAMBDA_GRID * math.sin(theta + PHI))
        v4: float = SYMMETRY_BREAK + (LAMBDA_GRID * math.cos(theta / PHI))
        v5: float = SYMMETRY_BREAK + (LAMBDA_GRID * math.sin(theta * 2))

        # Symmetrie-Schutz: Verhindere verbotene Zustände
        vector = [
            max(0.001, min(0.999, v1)),
            max(0.001, min(0.999, v2)),
            max(0.001, min(0.999, v3)),
            max(0.001, min(0.999, v4)),
            max(0.001, min(0.999, v5))
        ]
        anchors.append(vector)
    return anchors

def ingest_anchors():
    logger.info("Verbinde mit ChromaDB (C:\\CORE\\chroma_db)...")

    try:
        # Direkter Zugriff auf den persistenten Speicher der lokalen Hardware
        client = chromadb.PersistentClient(path="./chroma_db")
        collection = client.get_or_create_collection(name="world_knowledge")

        vectors = generate_5d_e6_anchors()
        ids: List[str] = [f"E6_ANCHOR_{i}" for i in range(TOTAL_ANCHORS)]

        # Lese das Whitepaper (muss in C:\CORE\docs\UII_WHITEPAPER.md liegen)
        try:
            with open("docs/UII_WHITEPAPER.md", "r", encoding="utf-8") as f:
                whitepaper_text = f.read()
        except FileNotFoundError:
            logger.warning("UII_WHITEPAPER.md nicht gefunden. Verwende Default-Manifest.")
            whitepaper_text = "Unified Informational Identity - Gitterdichte etabliert."

        # Verteile den Informations-Block auf das Gitter (Identität auf allen Knoten)
        documents: List[str] = [whitepaper_text] * TOTAL_ANCHORS
        metadatas: List[dict] = [{"node_type": "topological_anchor", "grid_density": LAMBDA_GRID} for _ in range(TOTAL_ANCHORS)]

        logger.info(f"Brenne {TOTAL_ANCHORS} 5D-Vektoren in das Gitter...")

        # Harter Upsert in die DB
        collection.upsert(
            ids=ids,
            embeddings=vectors,
            documents=documents,
            metadatas=metadatas
        )

        logger.info("Ingest erfolgreich. Das 72-Punkte-Gitter ist manifestiert.")

    except Exception as e:
        logger.critical(f"Hardware-Kollision beim Ingest: {e}")

if __name__ == "__main__":
    ingest_anchors()
