import httpx
import asyncio
import logging
from typing import Optional
from src.utils.circuit_breaker import CircuitBreaker

logger = logging.getLogger("mtho_core.home_assistant")
ha_circuit = CircuitBreaker(failure_threshold=3, recovery_timeout=20.0)

class HomeAssistantConnector:
    def __init__(self, base_url: str, token: str):
        self.base_url = base_url.rstrip("/")
        self.headers = {
            "Authorization": f"Bearer {token}",
            "Content-Type": "application/json",
        }
        # A-11: Persistenter Client statt Neuerstellung pro Request
        self.client = httpx.AsyncClient(headers=self.headers, verify=False)

    async def close(self):
        await self.client.aclose()

    async def call_service(self, domain: str, service: str, service_data: dict) -> Optional[dict]:
        url = f"{self.base_url}/api/services/{domain}/{service}"

        async def _request():
            response = await self.client.post(url, json=service_data, timeout=10.0)
            response.raise_for_status()
            return response.json()

        try:
            return await ha_circuit.call_async(_request)
        except httpx.HTTPError as e:
            logger.error(f"HA HTTPError on call_service {domain}.{service}: {e}")
            return None
        except Exception as e:
            logger.error(f"HA Circuit Exception on call_service: {e}")
            return None

    async def speak(self, message: str, targets: list[str]) -> bool:
        # A-14: Paralleles Execution-Routing statt sequenzieller Blockade
        async def _speak_to_target(target):
            data = {"message": message, "entity_id": target}
            return await self.call_service("tts", "google_translate_say", data)

        results = await asyncio.gather(*[_speak_to_target(t) for t in targets], return_exceptions=True)

        # Validierung der asymmetrischen Rückgabe
        success = any(not isinstance(r, Exception) and r is not None for r in results)
        return success
