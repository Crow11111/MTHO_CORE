import os
import chromadb
import logging

logger = logging.getLogger("mtho_core.chroma")

CHROMA_MAX_SIZE_MB = 1024 # Int für Infrastruktur-Domäne
CHROMA_PATH = "./chroma_db"

class PersistentChromaClient:
    def __init__(self):
        self.client = chromadb.PersistentClient(path=CHROMA_PATH)
        self._init_collections()

    def _init_collections(self):
        # A-22: world_knowledge implementiert
        self.world_knowledge = self.client.get_or_create_collection(name="world_knowledge")
        self.events = self.client.get_or_create_collection(name="events")
        self.wuji_context = self.client.get_or_create_collection(name="wuji_context") # ehemals Wuji, jetzt BASE_STATE data

    def _check_disk_quota(self) -> bool:
        # A-28: Zero-Trust Disk Quota
        total_size = 0
        for dirpath, _, filenames in os.walk(CHROMA_PATH):
            for f in filenames:
                fp = os.path.join(dirpath, f)
                if not os.path.islink(fp):
                    total_size += os.path.getsize(fp)

        size_mb = total_size / (1024 * 1024)
        if size_mb > CHROMA_MAX_SIZE_MB:
            logger.error(f"ChromaDB Quota exceeded: {size_mb:.2f} MB > {CHROMA_MAX_SIZE_MB} MB. Writes blocked.")
            return False
        return True

    def add_world_knowledge(self, documents: list[str], metadatas: list[dict], ids: list[str]):
        if not self._check_disk_quota():
            raise RuntimeError("ChromaDB Disk Quota Exceeded (A-28).")
        self.world_knowledge.add(documents=documents, metadatas=metadatas, ids=ids)
